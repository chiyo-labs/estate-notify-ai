# ================================================================
# estate-notify-ai 環境変数サンプル
# このファイルをコピーして .env.local を作成し、値を入力してください。
# ================================================================

# ----------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# ※ SUPABASE_SERVICE_ROLE_KEY は絶対に公開しないこと（NEXT_PUBLIC_ を付けない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------------
# Claude API (Anthropic)
# ----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------
# Slack
# ----------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_RENTAL=C000000001     # #賃貸 チャンネルID
SLACK_CHANNEL_SALE=C000000002       # #売買 チャンネルID
SLACK_CHANNEL_PREVIEW=C000000003    # #内見 チャンネルID
SLACK_CHANNEL_COMPLAINT=C000000004  # #クレーム チャンネルID

# ----------------------------------------------------------------
# LINE Messaging API
# ----------------------------------------------------------------
LINE_CHANNEL_SECRET=your-channel-secret          # Webhook署名検証用
LINE_CHANNEL_ACCESS_TOKEN=your-access-token      # メッセージ送信用
LINE_MANAGER_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # 営業部長のLINE User ID

# ----------------------------------------------------------------
# セキュリティ
# ----------------------------------------------------------------
# /api/cron/classify エンドポイントの保護トークン（Vercel Cronが自動送信）
CRON_SECRET=your-cron-secret

# /api/inquiry/email エンドポイントの Bearer 認証トークン
INTERNAL_API_SECRET=your-internal-api-secret
